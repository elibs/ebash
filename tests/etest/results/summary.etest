#-----------------------------------------------------------------------------------------------------------------------
#
# Setup
#
#-----------------------------------------------------------------------------------------------------------------------

setup()
{
    ETEST_LOG="summary-etest.log"
    ETEST_JSON="summary-etest.json"
    ETEST_FAILURE_LOG="summary-etest.failure.log"
    ETEST_STDERR_FD="/dev/null"
    COLUMNS=80
}

#-----------------------------------------------------------------------------------------------------------------------
#
# Tests
#
#-----------------------------------------------------------------------------------------------------------------------

ETEST_results_summary_passed()
{
    NUM_TESTS_EXECUTED=5
    NUM_TESTS_PASSED=5 TESTS_PASSED=( [suite]="test1 test2 test3 test4 test5" )
    NUM_TESTS_FAILED=0 TESTS_FAILED=()
    DURATION="${SECONDS}"

    etestmsg "Calling create_summary"
    create_summary

    etestmsg "Verifying files created"
    assert_exists "${ETEST_LOG}"
    assert_exists "${ETEST_JSON}"
    assert_exists "${ETEST_FAILURE_LOG}"
    [[ -s "${ETEST_JSON}" ]]

    etestmsg "Checking log file has no failure markers"
    assert_false grep "Failed Tests" "${ETEST_LOG}"

    etestmsg "Checking failure log is empty for passing tests"
    assert_false test -s "${ETEST_FAILURE_LOG}"

    etestmsg "Checking json file"
    jq . "${ETEST_JSON}"
    $(json_import --file "${ETEST_JSON}")
    assert_eq 5 "${numTestsExecuted}"
    assert_eq 5 "${numTestsPassed}"
    assert_eq 0 "${numTestsFailed}"
    assert_eq "${DURATION}s" "${duration}"

    etestmsg "Checking test suite results in json file"
    testsPassed="$(jq -r .testsPassed "${ETEST_JSON}" | tr -d '\n' | tr -d ' ')"
    assert_eq '[{"suite":"suite","tests":["test1","test2","test3","test4","test5"]}]' "${testsPassed}"
    testsFailed="$(jq -r .testsFailed "${ETEST_JSON}" | tr -d '\n' | tr -d ' ')"
    assert_eq '[]' "${testsFailed}"
}

ETEST_results_summary_failed()
{
    NUM_TESTS_EXECUTED=5
    NUM_TESTS_PASSED=0 TESTS_PASSED=()
    NUM_TESTS_FAILED=5 TESTS_FAILED=( [suite]="test1 test2 test3 test4 test5" )
    DURATION="${SECONDS}"

    etestmsg "Calling create_summary"
    create_summary

    etestmsg "Verifying files created and non-empty"
    assert_exists "${ETEST_LOG}"
    assert_exists "${ETEST_JSON}"
    assert_exists "${ETEST_FAILURE_LOG}"
    [[ -s "${ETEST_LOG}"  ]]
    [[ -s "${ETEST_JSON}" ]]

    etestmsg "Checking log file"
    noansi "${ETEST_LOG}"
    grep -q "Failed Tests" "${ETEST_LOG}"
    grep -q "FAILED" "${ETEST_LOG}"
    grep -q "test1" "${ETEST_LOG}"
    grep -q "test5" "${ETEST_LOG}"
    grep -q "5 FAILED TESTS" "${ETEST_LOG}"

    etestmsg "Checking json file"
    jq . "${ETEST_JSON}"
    $(json_import --file "${ETEST_JSON}")
    assert_eq 5 "${numTestsExecuted}"
    assert_eq 0 "${numTestsPassed}"
    assert_eq 5 "${numTestsFailed}"
    assert_eq "${DURATION}s" "${duration}"

    etestmsg "Checking test suite results in json file"
    testsPassed="$(jq -r .testsPassed "${ETEST_JSON}" | tr -d '\n' | tr -d ' ')"
    assert_eq '[]' "${testsPassed}"
    testsFailed="$(jq -r .testsFailed "${ETEST_JSON}" | tr -d '\n' | tr -d ' ')"
    assert_eq '[{"suite":"suite","tests":["test1","test2","test3","test4","test5"]}]' "${testsFailed}"
}

ETEST_results_summary_mixed()
{
    NUM_TESTS_EXECUTED=5
    NUM_TESTS_PASSED=4 TESTS_PASSED=( [suite]="test1 test3 test4 test5" )
    NUM_TESTS_FAILED=1 TESTS_FAILED=( [suite]="test2" )
    DURATION="${SECONDS}"

    etestmsg "Calling create_summary"
    create_summary

    etestmsg "Verifying files created and non-empty"
    assert_exists "${ETEST_LOG}"
    assert_exists "${ETEST_JSON}"
    assert_exists "${ETEST_FAILURE_LOG}"
    [[ -s "${ETEST_LOG}"  ]]
    [[ -s "${ETEST_JSON}" ]]

    etestmsg "Checking log file"
    noansi "${ETEST_LOG}"
    grep -q "Failed Tests" "${ETEST_LOG}"
    grep -q "test2" "${ETEST_LOG}"
    grep -q "1 FAILED TEST" "${ETEST_LOG}"

    etestmsg "Checking json file"
    jq . "${ETEST_JSON}"
    $(json_import --file "${ETEST_JSON}")
    assert_eq 5 "${numTestsExecuted}"
    assert_eq 4 "${numTestsPassed}"
    assert_eq 1 "${numTestsFailed}"
    assert_eq "${DURATION}s" "${duration}"

    etestmsg "Checking test suite results in json file"
    testsPassed="$(jq -r .testsPassed "${ETEST_JSON}" | tr -d '\n' | tr -d ' ')"
    assert_eq '[{"suite":"suite","tests":["test1","test3","test4","test5"]}]' "${testsPassed}"
    testsFailed="$(jq -r .testsFailed "${ETEST_JSON}" | tr -d '\n' | tr -d ' ')"
    assert_eq '[{"suite":"suite","tests":["test2"]}]' "${testsFailed}"
}

ETEST_results_failure_log_format()
{
    NUM_TESTS_EXECUTED=2
    NUM_TESTS_PASSED=1 TESTS_PASSED=( [mysuite]="passing_test" )
    NUM_TESTS_FAILED=1 TESTS_FAILED=( [mysuite]="ETEST_failing_test" )
    DURATION="${SECONDS}"

    # Create a mock per-test output.log file that __extract_test_output will read
    # statedir is ${testdir}.state (sibling directory pattern)
    mkdir -p "${workdir}/mysuite.etest/ETEST_failing_test.state"
    cat > "${workdir}/mysuite.etest/ETEST_failing_test.state/output.log" <<'EOF'
[2024-01-01T00:00:00Z] Running command="ETEST_failing_test" attempt="0"
Some test output here
Error: something went wrong
[2024-01-01T00:00:01Z] tests/example.etest:ETEST_failing_test FAILED.
EOF

    etestmsg "Calling create_summary"
    create_summary

    etestmsg "Checking failure log exists and has content"
    assert_exists "${ETEST_FAILURE_LOG}"
    [[ -s "${ETEST_FAILURE_LOG}" ]]

    etestmsg "Checking failure log format"
    grep -q "mysuite:failing_test" "${ETEST_FAILURE_LOG}"
    grep -q "Error: something went wrong" "${ETEST_FAILURE_LOG}"

    etestmsg "Checking failure log has no ANSI codes"
    assert_false grep -P '\x1b\[' "${ETEST_FAILURE_LOG}"
}

ETEST_results_failure_log_multiple_suites()
{
    NUM_TESTS_EXECUTED=4
    NUM_TESTS_PASSED=2 TESTS_PASSED=( [suite1]="pass1" [suite2]="pass2" )
    NUM_TESTS_FAILED=2 TESTS_FAILED=( [suite1]="ETEST_fail1" [suite2]="ETEST_fail2" )
    DURATION="${SECONDS}"

    # Create mock per-test output.log files that __extract_test_output will read
    # statedir is ${testdir}.state (sibling directory pattern)
    mkdir -p "${workdir}/suite1.etest/ETEST_fail1.state"
    cat > "${workdir}/suite1.etest/ETEST_fail1.state/output.log" <<'EOF'
[2024-01-01T00:00:00Z] Running command="ETEST_fail1" attempt="0"
Suite1 failure output
[2024-01-01T00:00:01Z] tests/suite1.etest:ETEST_fail1 FAILED.
EOF

    mkdir -p "${workdir}/suite2.etest/ETEST_fail2.state"
    cat > "${workdir}/suite2.etest/ETEST_fail2.state/output.log" <<'EOF'
[2024-01-01T00:00:02Z] Running command="ETEST_fail2" attempt="0"
Suite2 failure output
[2024-01-01T00:00:03Z] tests/suite2.etest:ETEST_fail2 FAILED.
EOF

    etestmsg "Calling create_summary"
    create_summary

    etestmsg "Checking failure log contains both failures"
    assert_exists "${ETEST_FAILURE_LOG}"
    [[ -s "${ETEST_FAILURE_LOG}" ]]
    grep -q "suite1:fail1" "${ETEST_FAILURE_LOG}"
    grep -q "suite2:fail2" "${ETEST_FAILURE_LOG}"
    grep -q "Suite1 failure output" "${ETEST_FAILURE_LOG}"
    grep -q "Suite2 failure output" "${ETEST_FAILURE_LOG}"
}
