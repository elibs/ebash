#-----------------------------------------------------------------------------------------------------------------------
#
# Tests: Test function naming with dashes
#
# Verify that test functions can use dashes in their names (e.g., ETEST-foo-bar) in addition to the traditional
# underscore style (ETEST_foo_bar).
#
#-----------------------------------------------------------------------------------------------------------------------

# Test using dash after ETEST prefix
ETEST-dash_prefix()
{
    etestmsg "Test with dash after ETEST prefix works"
    assert_true true
}

# Test using all dashes
ETEST-all-dashes-in-name()
{
    etestmsg "Test with all dashes works"
    assert_true true
}

# Test mixing dashes and underscores
ETEST_mixed-dashes_and-underscores()
{
    etestmsg "Test with mixed dashes and underscores works"
    assert_true true
}

# Traditional underscore style still works
ETEST_traditional_underscores()
{
    etestmsg "Traditional underscore style still works"
    assert_true true
}
