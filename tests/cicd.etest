# Helper string of git config settings to use for `git commit` and `git tag` operations to use known configurations.
git_config_options="-c user.name='Neo' -c user.email='neo@matrix.com'"

# Mock git function to intercept "git push" commands for better testability.
git_tags_pushed=()
git()
{
    if [[ "${1}" == "push" ]]; then
        etestmsg "Simulating git push tags=${*}"
        shift
        shift
        git_tags_pushed+=( "${@}" )
        return 0
    elif [[ "${1}" == @(pull|fetch) ]]; then
        return 0
    fi

    command git ${git_config_options} "${@}"
}

setup()
{
    # Mock out a git repository here in our current working directory. This way we can have a very controlled
    # environment and make tighter assertions.
    etestmsg "Mocking out git repository"
    git init
    git checkout -b 'main'
    git remote add origin git@github.com:elibs/etest.git
    git remote set-url origin git@github.com:elibs/etest.git
    touch "file1.txt"
    git add "file1.txt"
    git commit -am "Add file1.txt"
    git tag -am "Tagged by etest" "v1.0.0"

    # Ensure subsequent tags have different timestamps so git describe returns the most recent tag
    sleep 1
}

ETEST_cicd_info()
{
    # Create CICD Pack
    etestmsg "Test CI/CD Info"
    cicd_info info
    $(pack_import info)
    cicd_print --json info

    etestmsg "Validating CI/CD Info"
    assert_eq "v1.0.0"                              "${base_tag}"
    assert_eq "main"                                "${branch}"
    assert_eq "$(git rev-parse HEAD)"               "${commit}"
    assert_eq "$(git rev-parse HEAD | cut -c1-10)"  "${commit_short}"
    assert_eq "1"                                   "${major}"
    assert_eq "0"                                   "${minor}"
    assert_eq "0"                                   "${patch}"
    assert_eq "0"                                   "${offset}"
    assert_eq "git@github.com:elibs/etest.git"      "${origin_url}"
    assert_eq "etest"                               "${repo_slug}"
    assert_eq "1.0"                                 "${series}"
    assert_eq "1.0.0"                               "${version}"
    assert_eq "v1.0.0"                              "${version_tag}"
    assert_eq "v1.0.1"                              "${version_tag_next}"
}

ETEST_cicd_info_notags()
{
    etestmsg "Deleting tag created in setup"
    git tag -d "v1.0.0"

    # Create CICD Pack
    etestmsg "Test CI/CD Info"
    cicd_info info
    $(pack_import info)
    cicd_print --json info

    etestmsg "Validating CI/CD Info"
    assert_eq "v0.0.0"                              "${base_tag}"
    assert_eq "main"                                "${branch}"
    assert_eq "$(git rev-parse HEAD)"               "${commit}"
    assert_eq "$(git rev-parse HEAD | cut -c1-10)"  "${commit_short}"
    assert_eq "0"                                   "${major}"
    assert_eq "0"                                   "${minor}"
    assert_eq "0"                                   "${patch}"
    assert_eq "0"                                   "${offset}"
    assert_eq "git@github.com:elibs/etest.git"      "${origin_url}"
    assert_eq "etest"                               "${repo_slug}"
    assert_eq "0.0"                                 "${series}"
    assert_eq "0.0.0"                               "${version}"
    assert_eq "v0.0.0"                              "${version_tag}"
    assert_eq "v0.0.1"                              "${version_tag_next}"
}

ETEST_cicd_info_offset()
{
    etestmsg "Adding another commit"
    echo "foo" > "file1.txt"
    git add "file1.txt"
    git status
    git commit -am "Bump file1.txt"

    # Create CICD Pack
    etestmsg "Test CI/CD Info"
    cicd_info info
    $(pack_import info)
    cicd_print --json info

    etestmsg "Validating CI/CD Info"
    assert_eq "v1.0.0"                              "${base_tag}"
    assert_eq "main"                                "${branch}"
    assert_eq "$(git rev-parse HEAD)"               "${commit}"
    assert_eq "$(git rev-parse HEAD | cut -c1-10)"  "${commit_short}"
    assert_eq "1"                                   "${major}"
    assert_eq "0"                                   "${minor}"
    assert_eq "0"                                   "${patch}"
    assert_eq "1"                                   "${offset}"
    assert_eq "git@github.com:elibs/etest.git"      "${origin_url}"
    assert_eq "etest"                               "${repo_slug}"
    assert_eq "1.0"                                 "${series}"
    assert_eq "1.0.0-1-g${commit_short}"            "${version}"
    assert_eq "v1.0.0-1-g${commit_short}"           "${version_tag}"
    assert_eq "v1.0.1"                              "${version_tag_next}"
}

ETEST_cicd_info_print()
{
    # Create CICD Pack
    etestmsg "Test CI/CD Info"
    cicd_info info
    $(pack_import info)
    cicd_print info > output

	cat > expect <<-EOF
	base_tag="v1.0.0"
	branch="main"
	commit="${commit}"
	commit_short="${commit_short}"
	major="1"
	minor="0"
	patch="0"
	offset="0"
	origin_url="git@github.com:elibs/etest.git"
	repo_slug="etest"
	series="1.0"
	version="1.0.0"
	version_tag="v1.0.0"
	version_tag_next="v1.0.1"
	EOF

    einfo "Expect"
    cat expect

    einfo "Actual"
    cat output

    diff -u expect output
}

ETEST_cicd_info_print_json()
{
    # Create CICD Pack
    etestmsg "Test CI/CD Info"
    cicd_info info
    $(pack_import info)
    cicd_print --json info > output.json

	cat > expect.json <<-EOF
	{
	  "base_tag": "v1.0.0",
	  "branch": "main",
	  "commit": "${commit}",
	  "commit_short": "${commit_short}",
	  "major": "1",
	  "minor": "0",
	  "patch": "0",
	  "offset": "0",
	  "origin_url": "git@github.com:elibs/etest.git",
	  "repo_slug": "etest",
	  "series": "1.0",
	  "version": "1.0.0",
	  "version_tag": "v1.0.0",
	  "version_tag_next": "v1.0.1"
	}
	EOF

    einfo "Expect"
    jq . expect.json

    einfo "Actual"
    jq . output.json

    diff -u expect.json output.json
}

ETEST_cicd_info_print_uppercase()
{
    # Create CICD Pack
    etestmsg "Test CI/CD Info (uppercase)"
    cicd_info info
    $(pack_import info)
    cicd_print --uppercase info > output

	cat > expect <<-EOF
	BASE_TAG="v1.0.0"
	BRANCH="main"
	COMMIT="${commit}"
	COMMIT_SHORT="${commit_short}"
	MAJOR="1"
	MINOR="0"
	PATCH="0"
	OFFSET="0"
	ORIGIN_URL="git@github.com:elibs/etest.git"
	REPO_SLUG="etest"
	SERIES="1.0"
	VERSION="1.0.0"
	VERSION_TAG="v1.0.0"
	VERSION_TAG_NEXT="v1.0.1"
	EOF

    einfo "Expect"
    cat expect

    einfo "Actual"
    cat output

    diff -u expect output
}

ETEST_cicd_create_next_version_tag()
{
    # Create CICD Pack
    etestmsg "Test CI/CD Info"
    cicd_info info
    $(pack_import info)
    cicd_print --json info

    etestmsg "Creating next version tag"
    cicd_create_next_version_tag
    cicd_info info
    $(pack_import info)
    cicd_print --json info

    etestmsg "Validating CI/CD Info"
    assert_eq "v1.0.1"                              "${base_tag}"
    assert_eq "main"                                "${branch}"
    assert_eq "$(git rev-parse HEAD)"               "${commit}"
    assert_eq "$(git rev-parse HEAD | cut -c1-10)"  "${commit_short}"
    assert_eq "1"                                   "${major}"
    assert_eq "0"                                   "${minor}"
    assert_eq "1"                                   "${patch}"
    assert_eq "0"                                   "${offset}"
    assert_eq "git@github.com:elibs/etest.git"      "${origin_url}"
    assert_eq "etest"                               "${repo_slug}"
    assert_eq "1.0"                                 "${series}"
    assert_eq "1.0.1"                               "${version}"
    assert_eq "v1.0.1"                              "${version_tag}"
    assert_eq "v1.0.2"                              "${version_tag_next}"
}

ETEST_cicd_create_next_version_tag_push()
{
    # Create CICD Pack
    etestmsg "Test CI/CD Info"
    cicd_info info
    $(pack_import info)
    cicd_print --json info

    etestmsg "Creating next version tag"
    cicd_create_next_version_tag --push
    cicd_info info
    $(pack_import info)
    cicd_print --json info

    etestmsg "$(lval git_tags_pushed)"
    assert_eq 2                     "$(array_size git_tags_pushed)"
    assert_eq "main"                "${git_tags_pushed[0]}"
    assert_eq "${version_tag}"      "${git_tags_pushed[1]}"
}

ETEST_cicd_create_next_version_tag_custom_branch()
{
    etestmsg "Create and switch to develop branch"
    git checkout -b "develop"

    etestmsg "Creating next version tag with --branch develop"
    cicd_create_next_version_tag --branch develop
    cicd_info info
    $(pack_import info)
    cicd_print --json info

    etestmsg "Validating tag was created"
    assert_eq "v1.0.1"  "${version_tag}"
    assert_eq "develop" "${branch}"
}

ETEST_cicd_create_next_version_branch_error()
{
    etestmsg "Switching to a feature branch"
    git checkout -b "feature/foo"

    # Create CICD Pack
    etestmsg "Test CI/CD Info"
    cicd_info info
    $(pack_import info)
    cicd_print --json info
    assert_eq "feature/foo" "${branch}"

    etestmsg "Verifying cicd_create_next_version_tag fails due to feature branch"
    assert_false cicd_create_next_version_tag --push
}

ETEST_cicd_release_two_branch()
{
    etestmsg "Create develop branch for two-branch workflow test"
    git checkout -b "develop"

    # Create CICD Pack
    etestmsg "Test CI/CD Info"
    cicd_info info
    $(pack_import info)
    cicd_print --json info

    etestmsg "Creating next version tag on develop"
    cicd_create_next_version_tag --branch develop
    cicd_info info
    $(pack_import info)
    cicd_print --json info

    etestmsg "Testing cicd_release with two-branch workflow"
    cicd_release --from develop --to main
    etestmsg "$(lval git_tags_pushed)"
    assert_eq 1           "$(array_size git_tags_pushed)"
    assert_eq "HEAD:main" "${git_tags_pushed[0]}"
}

ETEST_cicd_release_single_branch()
{
    etestmsg "Testing cicd_release with single-branch workflow (no-op)"
    cicd_release --from main --to main
    etestmsg "$(lval git_tags_pushed)"
    assert_eq 0 "$(array_size git_tags_pushed)"
}

ETEST_cicd_release_branch_error()
{
    etestmsg "Switching to a feature branch"
    git checkout -b "feature/foo"

    # Create CICD Pack
    etestmsg "Test CI/CD Info"
    cicd_info info
    $(pack_import info)
    cicd_print --json info
    assert_eq "feature/foo" "${branch}"

    etestmsg "Verifying cicd_release fails due to feature branch"
    assert_false cicd_release --from develop --to main
    assert_eq 0           "$(array_size git_tags_pushed)"
}

ETEST_cicd_info_rc_suffix()
{
    etestmsg "Deleting default tag and creating RC tag"
    git tag -d "v1.0.0"
    git tag -am "Tagged by etest" "v2.1.0-rc1"

    # Create CICD Pack
    etestmsg "Test CI/CD Info with RC suffix"
    cicd_info info
    $(pack_import info)
    cicd_print --json info

    etestmsg "Validating CI/CD Info"
    # The -rc1 suffix is stripped when calculating base_tag and version components
    assert_eq "v2.1.0"                              "${base_tag}"
    assert_eq "main"                                "${branch}"
    assert_eq "$(git rev-parse HEAD)"               "${commit}"
    assert_eq "$(git rev-parse HEAD | cut -c1-10)"  "${commit_short}"
    assert_eq "2"                                   "${major}"
    assert_eq "1"                                   "${minor}"
    assert_eq "0"                                   "${patch}"
    assert_eq "0"                                   "${offset}"
    assert_eq "git@github.com:elibs/etest.git"      "${origin_url}"
    assert_eq "etest"                               "${repo_slug}"
    assert_eq "2.1"                                 "${series}"
    # version and version_tag retain the full tag including -rc1
    assert_eq "2.1.0-rc1"                           "${version}"
    assert_eq "v2.1.0-rc1"                          "${version_tag}"
    # Next version is the final release (not incremented) since this is an RC
    assert_eq "v2.1.0"                              "${version_tag_next}"
}

ETEST_cicd_info_rc_suffix_with_offset()
{
    etestmsg "Deleting default tag and creating RC tag"
    git tag -d "v1.0.0"
    git tag -am "Tagged by etest" "v2.1.0-rc1"

    etestmsg "Adding a commit after the RC tag"
    echo "post-rc change" >> "file1.txt"
    git add "file1.txt"
    git commit -am "Post-RC commit"

    # Create CICD Pack
    # git describe will now return something like: v2.1.0-rc1-1-g<hash>
    etestmsg "Test CI/CD Info with RC suffix and offset"
    cicd_info info
    $(pack_import info)
    cicd_print --json info

    etestmsg "Validating CI/CD Info"
    # The -rc1-1-g<hash> suffix is stripped when calculating base_tag
    assert_eq "v2.1.0"                              "${base_tag}"
    assert_eq "main"                                "${branch}"
    assert_eq "$(git rev-parse HEAD)"               "${commit}"
    assert_eq "$(git rev-parse HEAD | cut -c1-10)"  "${commit_short}"
    assert_eq "2"                                   "${major}"
    assert_eq "1"                                   "${minor}"
    assert_eq "0"                                   "${patch}"
    # offset is 0 because base_tag (v2.1.0) doesn't exist as a real tag - the actual tag is v2.1.0-rc1
    assert_eq "0"                                   "${offset}"
    assert_eq "git@github.com:elibs/etest.git"      "${origin_url}"
    assert_eq "etest"                               "${repo_slug}"
    assert_eq "2.1"                                 "${series}"
    # version and version_tag include the full git describe output
    assert_match "${version}"                       "2.1.0-rc1-1-g"
    assert_match "${version_tag}"                   "v2.1.0-rc1-1-g"
    # Next version should be the final release (v2.1.0), not an incremented patch
    assert_eq "v2.1.0"                              "${version_tag_next}"
}

ETEST_cicd_version()
{
    etestmsg "Set origin to ebash repo for this test"
    git remote set-url origin git@github.com:elibs/ebash.git

    etestmsg "Test cicd_version from git describe (preferred in ebash repo)"
    local ver
    ver=$(cicd_version)
    assert_not_empty "${ver}"
    assert_match "${ver}" "^v[0-9]"

    etestmsg "Test cicd_version prefers git over VERSION file in ebash repo"
    echo "v9.9.9" > VERSION
    ver=$(cicd_version --file=VERSION)
    # Should use git describe (v1.0.0 from setup), not VERSION file
    assert_match "${ver}" "^v1.0.0"

    etestmsg "Test cicd_version_update"
    cicd_version_update --file=VERSION_TEST
    assert_exists VERSION_TEST
    local written_ver
    read -r written_ver < VERSION_TEST
    assert_match "${written_ver}" "^v[0-9]"
}

ETEST_cicd_version_non_ebash_repo()
{
    etestmsg "Ensure origin is NOT ebash (using etest from setup)"
    local origin
    origin=$(git remote get-url origin)
    if [[ "${origin}" == *ebash* ]]; then
        die "Origin should not match ebash"
    fi

    etestmsg "Create VERSION file with known version"
    echo "v8.8.8 (2025-01-01)" > VERSION

    etestmsg "Test cicd_version uses VERSION file (not git) in non-ebash repo"
    local ver
    ver=$(cicd_version --file=VERSION)
    assert_eq "v8.8.8 (2025-01-01)" "${ver}"

    etestmsg "Test cicd_version returns unknown when no VERSION file in non-ebash repo"
    ver=$(cicd_version)
    assert_eq "unknown" "${ver}"
}

ETEST_cicd_update_version_files()
{
    etestmsg "Test updating VERSION file"
    cicd_update_version_files --tag "v1.2.3" --version-file VERSION
    assert_exists VERSION
    assert_eq "v1.2.3 ($(date +%Y-%m-%d))" "$(cat VERSION)"

    etestmsg "Test updating README without existing badge"
    cat > README.md <<'EOF'
[![CI/CD](https://example.com/badge.svg)](https://example.com)

# My Project
EOF

    cicd_update_version_files --tag "v1.2.3" --readme README.md --release-url "https://github.com/test/repo/releases"
    cat README.md
    assert_true grep -q "Version" README.md
    assert_true grep -q "v1.2.3" README.md
    assert_true grep -q "https://github.com/test/repo/releases" README.md

    etestmsg "Test updating README with existing badge"
    cicd_update_version_files --tag "v2.0.0" --readme README.md --release-url "https://github.com/test/repo/releases"
    cat README.md
    assert_true grep -q "v2.0.0" README.md
    assert_false grep -q "v1.2.3" README.md

    etestmsg "Test with commit"
    cicd_update_version_files --tag "v3.0.0" --version-file VERSION --commit
    assert_eq "v3.0.0 ($(date +%Y-%m-%d))" "$(cat VERSION)"
    # Verify the commit was made
    assert_true git log -1 --oneline | grep -q "Update version to v3.0.0"
}
