# Verify appending to an archive with --delete (not supported for iso/squashfs)
archive_append_delete_test()
{
    $(skip_if '[[ ${EUID} -ne 0 ]]')
    local ftype=$1

    etestmsg "Populating source directory"
    efreshdir src dest
    touch src/{file1,file2}

    etestmsg "Creating src.${ftype}"
    archive_create src.${ftype} src
    assert_archive_contents src.${ftype} src src/file1 src/file2

    etestmsg "Appending additional files to src.${ftype} with --delete"
    touch src/{file3,file4}
    archive_append --delete src.${ftype} src/file3 src/file4
    assert_archive_contents src.${ftype} src src/file1 src/file2 src/file3 src/file4

    etestmsg "Ensuring source files were deleted"
    assert_not_exists src/file3 src/file4
}

