# Test that archive_append doesn't corrupt archive with shadow mount (files)
archive_append_no_shadow_mount_files_test()
{
    $(skip_if '[[ ${EUID} -ne 0 ]]')
    local ftype=$1

    etestmsg "Populating source directory"
    efreshdir src dest
    touch src/{file1,file2}

    etestmsg "Creating src.${ftype}"
    archive_create src.${ftype} src
    assert_archive_contents src.${ftype} src src/file1 src/file2

    etestmsg "Appending file with same name as archive"
    touch src.${ftype}.new
    archive_append src.${ftype} src.${ftype}.new
    assert_archive_contents src.${ftype} src src/file1 src/file2 src.${ftype}.new
}

