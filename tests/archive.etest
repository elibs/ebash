# Verify we can use archive_create with a custom archive suffix and that it will properly be able to detect it via the
# -t flag.
ETEST_archive_create_custom_suffix()
{
    $(skip_if '[[ ${EUID} -ne 0 ]]')

    etestmsg "Populating source directory"
    efreshdir src
    touch src/{file1,file2}

    etestmsg "Creating dest.img"
    archive_create -t=tar dest.img src
    archive_list -t=tar dest.img
    assert_archive_contents -t=tar dest.img src src/file1 src/file2
}

archive_create_mount_test()
{
    $(skip_if '[[ ${EUID} -ne 0 ]]')
    local ftype=$1

    etestmsg "Creating source directory"
    efreshdir src
    mkdir src/sub1 src/sub2
    touch src/{file1,file2}
    touch src/sub1/{file1,file2}
    touch src/sub2/{file3,file4}

    etestmsg "Creating src.${ftype}"
    archive_create src.${ftype} src

    etestmsg "Mounting src.${ftype} and validating contents"
    archive_mount src.${ftype} mnt
    assert_directory_contents mnt src src/file1 src/file2 src/sub1 src/sub1/file1 src/sub1/file2 src/sub2 src/sub2/file3 src/sub2/file4

    etestmsg "Unmounting src.${ftype}"
    eunmount --recursive mnt
}

