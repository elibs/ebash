    etestmsg "Creating source directory"
    efreshdir src dest
    mkdir -p src/A/sub src/B/sub
    touch src/A/{f1,f2} src/A/sub/{as1,as2}
    touch src/B/{f3,f4} src/B/sub/{bs1,bs2}

    etestmsg "Creating src.${ftype}"
    archive_create src.${ftype} src

    etestmsg "Extracting src.${ftype} to dest --strip=2"
    archive_extract --strip=2 src.${ftype} dest

    # Directories with the same name arg merged
    assert_directory_contents dest f1 f2 f3 f4 sub sub/as1 sub/as2 sub/bs1 sub/bs2
}

ETEST_archive_extract_strip_collisions_cgz()      { archive_extract_strip_collisions_test cgz;      }
ETEST_archive_extract_strip_collisions_cpio()     { archive_extract_strip_collisions_test cpio;     }
ETEST_archive_extract_strip_collisions_cxz()      { archive_extract_strip_collisions_test cxz;      }
ETEST_archive_extract_strip_collisions_tar()      { archive_extract_strip_collisions_test tar;      }
ETEST_archive_extract_strip_collisions_tar_gz()   { archive_extract_strip_collisions_test tar.gz;   }
ETEST_archive_extract_strip_collisions_tlz()      { archive_extract_strip_collisions_test tlz;      }
ETEST_archive_extract_strip_collisions_iso()      { archive_extract_strip_collisions_test iso;      }
ETEST_archive_extract_strip_collisions_squashfs() { archive_extract_strip_collisions_test squashfs; }

# Verify appending to an archive (not supported for iso/squashfs)
archive_append_test()
{
    $(skip_if '[[ ${EUID} -ne 0 ]]')
    local ftype=$1

    etestmsg "Populating source directory"
    efreshdir src dest
    touch src/{file1,file2}

    etestmsg "Creating src.${ftype}"
    archive_create src.${ftype} src
    assert_archive_contents src.${ftype} src src/file1 src/file2

    etestmsg "Appending additional files to src.${ftype}"
    touch src/{file3,file4}
    archive_append src.${ftype} src/file3 src/file4
    assert_archive_contents src.${ftype} src src/file1 src/file2 src/file3 src/file4
}

