# Verify appending to an archive with overwriting (not supported for iso/squashfs)
archive_append_overwrite_test()
{
    $(skip_if '[[ ${EUID} -ne 0 ]]')
    local ftype=$1

    etestmsg "Populating source directory"
    efreshdir src dest
    echo "original" > src/file1
    touch src/file2

    etestmsg "Creating src.${ftype}"
    archive_create src.${ftype} src
    assert_archive_contents src.${ftype} src src/file1 src/file2

    etestmsg "Appending updated file1 to src.${ftype}"
    echo "updated" > src/file1
    archive_append src.${ftype} src/file1
    assert_archive_contents src.${ftype} src src/file1 src/file2

    etestmsg "Extracting and verifying updated content"
    archive_extract src.${ftype} dest
    assert_eq "updated" "$(cat dest/src/file1)"
}

ETEST_archive_append_overwrite_cgz()    { archive_append_overwrite_test cgz;    }
ETEST_archive_append_overwrite_cpio()   { archive_append_overwrite_test cpio;   }
