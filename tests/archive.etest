# Verify appending to non-existing archive creates it (not supported for iso/squashfs)
archive_append_nonexisting_test()
{
    $(skip_if '[[ ${EUID} -ne 0 ]]')
    local ftype=$1

    etestmsg "Populating source directory"
    efreshdir src dest
    touch src/{file1,file2}

    etestmsg "Appending to nonexisting archive (should create it)"
    assert_not_exists nonexisting.${ftype}
    archive_append nonexisting.${ftype} src/file1 src/file2
    assert_exists nonexisting.${ftype}

    etestmsg "Extracting and verifying contents"
    archive_extract nonexisting.${ftype} dest
    assert_directory_contents dest src src/file1 src/file2
}

