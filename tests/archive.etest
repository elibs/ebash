archive_create_symlinks_test()
{
    $(skip_if '[[ ${EUID} -ne 0 ]]')
    local ftype=$1

    etestmsg "Populating source directory"
    efreshdir src
    touch src/{file1,file2}
    mkdir src/dir1
    echo "foo" > foo
    ln -s ./foo  src/filelnk
    ln -s ./dir1 src/dirlnk
    find src -ls

    etestmsg "Creating dest.${ftype}"
    archive_create dest.${ftype} src
    assert_archive_contents dest.${ftype} src src/dir1 src/dirlnk src/filelnk src/file1 src/file2

    etestmsg "Ensuring symlinks preserved"
    archive_extract dest.${ftype} dest
    [[ -L dest/src/filelnk ]]
    [[ -L dest/src/dirlnk  ]]
}

ETEST_archive_create_symlinks_cgz()      { archive_create_symlinks_test cgz;      }
ETEST_archive_create_symlinks_cpio()     { archive_create_symlinks_test cpio;     }
ETEST_archive_create_symlinks_cxz()      { archive_create_symlinks_test cxz;      }
ETEST_archive_create_symlinks_tar()      { archive_create_symlinks_test tar;      }
ETEST_archive_create_symlinks_tar_gz()   { archive_create_symlinks_test tar.gz;   }
ETEST_archive_create_symlinks_tlz()      { archive_create_symlinks_test tlz;      }
ETEST_archive_create_symlinks_iso()      { archive_create_symlinks_test iso;      }
ETEST_archive_create_symlinks_squashfs() { archive_create_symlinks_test squashfs; }

archive_create_symlinks_contents_test()
{
    $(skip_if '[[ ${EUID} -ne 0 ]]')
    local ftype=$1

    etestmsg "Populating source directory with symlinks"
    efreshdir src
    touch src/{file1,file2}
    echo "foo" > foo
    ln -s ${PWD}/foo src/filelnk
    ln -s ${PWD}/.  src/dirlnk
    find src -ls

    etestmsg "Creating dest.${ftype}"
    archive_create dest.${ftype} src/.
    assert_archive_contents dest.${ftype} filelnk file1 file2 dirlnk

    etestmsg "Ensuring symlinks preserved"
    archive_extract dest.${ftype} dest
    [[ -L dest/filelnk ]]
    [[ -L dest/dirlnk  ]]
}

ETEST_archive_create_symlinks_contents_cgz()      { archive_create_symlinks_contents_test cgz;      }
ETEST_archive_create_symlinks_contents_cpio()     { archive_create_symlinks_contents_test cpio;     }
ETEST_archive_create_symlinks_contents_cxz()      { archive_create_symlinks_contents_test cxz;      }
ETEST_archive_create_symlinks_contents_tar()      { archive_create_symlinks_contents_test tar;      }
ETEST_archive_create_symlinks_contents_tar_gz()   { archive_create_symlinks_contents_test tar.gz;   }
ETEST_archive_create_symlinks_contents_tlz()      { archive_create_symlinks_contents_test tlz;      }
ETEST_archive_create_symlinks_contents_iso()      { archive_create_symlinks_contents_test iso;      }
ETEST_archive_create_symlinks_contents_squashfs() { archive_create_symlinks_contents_test squashfs; }

# --dereference flag only supported for tar formats.
archive_create_symlinks_dereference_not_supported_test()
{
    $(skip_if '[[ ${EUID} -ne 0 ]]')
    local ftype=$1

    if [[ $(archive_type "dest.${ftype}") != "tar" ]]; then
        etestmsg "Creating dest.${ftype} (should fail)"
        mkdir -p src
        assert_false archive_create --dereference dest.${ftype} src
    fi
}

ETEST_archive_create_symlinks_dereference_not_supported_cgz()      { archive_create_symlinks_dereference_not_supported_test cgz;      }
ETEST_archive_create_symlinks_dereference_not_supported_cpio()     { archive_create_symlinks_dereference_not_supported_test cpio;     }
ETEST_archive_create_symlinks_dereference_not_supported_cxz()      { archive_create_symlinks_dereference_not_supported_test cxz;      }
ETEST_archive_create_symlinks_dereference_not_supported_iso()      { archive_create_symlinks_dereference_not_supported_test iso;      }
ETEST_archive_create_symlinks_dereference_not_supported_squashfs() { archive_create_symlinks_dereference_not_supported_test squashfs; }

archive_create_symlinks_dereference_test()
{
    $(skip_if '[[ ${EUID} -ne 0 ]]')
    local ftype=$1

    etestmsg "Populating source directory"
    efreshdir src
    touch src/{file1,file2}
    echo "foo" > foo
    ln -s ${PWD}/foo src/filelnk
    find src -ls

    etestmsg "Creating dest.${ftype}"
    archive_create --dereference dest.${ftype} src
    assert_archive_contents dest.${ftype} src src/filelnk src/file1 src/file2

    etestmsg "Ensuring symlinks dereferenced"
    archive_extract dest.${ftype} dest
    find dest -ls
    [[ ! -L dest/src/filelnk ]]
}

# --dereference only supported for tar formats
ETEST_archive_create_symlinks_dereference_tar()    { archive_create_symlinks_dereference_test tar;    }
ETEST_archive_create_symlinks_dereference_tar_gz() { archive_create_symlinks_dereference_test tar.gz; }

archive_create_level_test()
{
    $(skip_if '[[ ${EUID} -ne 0 ]]')
    local ftype=$1

    etestmsg "Populating source directory"
    efreshdir src
    touch src/{file1,file2}

    etestmsg "Creating dest.${ftype}"
    archive_create --level 1 dest.${ftype} src
    assert_archive_contents dest.${ftype} src src/file1 src/file2
    rm dest.${ftype}

    archive_create --level 9 dest.${ftype} src
    assert_archive_contents dest.${ftype} src src/file1 src/file2
    rm dest.${ftype}

    archive_create --fast dest.${ftype} src
    assert_archive_contents dest.${ftype} src src/file1 src/file2
    rm dest.${ftype}

    archive_create --best dest.${ftype} src
    assert_archive_contents dest.${ftype} src src/file1 src/file2
    rm dest.${ftype}
}

ETEST_archive_create_level_cgz()      { archive_create_level_test cgz;      }
ETEST_archive_create_level_cpio()     { archive_create_level_test cpio;     }
ETEST_archive_create_level_cxz()      { archive_create_level_test cxz;      }
ETEST_archive_create_level_tar()      { archive_create_level_test tar;      }
ETEST_archive_create_level_tar_gz()   { archive_create_level_test tar.gz;   }
ETEST_archive_create_level_tlz()      { archive_create_level_test tlz;      }
ETEST_archive_create_level_iso()      { archive_create_level_test iso;      }
ETEST_archive_create_level_squashfs() { archive_create_level_test squashfs; }

