archive_create_missing_files_test()
{
    $(skip_if '[[ ${EUID} -ne 0 ]]')
    local ftype=$1

    etestmsg "Creating files"
    touch {file1,file2,file3,file4}

    etestmsg "Creating src.${ftype} (should do nothing)"
    archive_create -i src.${ftype} NOT1 NOT2
    assert_not_exists src.${ftype}

    etestmsg "Creating src.${ftype} (should fail)"
    assert_false archive_create src.${ftype} NOT1 file1 file2 file3 file4 NOT2
    #BUG: assert_not_exists src.${ftype}

    etestmsg "Creating src.${ftype} (ignoring missing files -- should pass)"
    archive_create -i src.${ftype} NOT1 file1 file2 file3 file4 NOT2
    assert_archive_contents src.${ftype} file1 file2 file3 file4

    rm src.${ftype}
}

ETEST_archive_create_missing_files_cgz()      { archive_create_missing_files_test cgz;      }
ETEST_archive_create_missing_files_cpio()     { archive_create_missing_files_test cpio;     }
ETEST_archive_create_missing_files_cxz()      { archive_create_missing_files_test cxz;      }
ETEST_archive_create_missing_files_tar()      { archive_create_missing_files_test tar;      }
ETEST_archive_create_missing_files_tar_gz()   { archive_create_missing_files_test tar.gz;   }
ETEST_archive_create_missing_files_tlz()      { archive_create_missing_files_test tlz;      }
ETEST_archive_create_missing_files_iso()      { archive_create_missing_files_test iso;      }
ETEST_archive_create_missing_files_squashfs() { archive_create_missing_files_test squashfs; }

archive_create_mixed_files_directories_test()
{
    $(skip_if '[[ ${EUID} -ne 0 ]]')
    local ftype=$1

    etestmsg "Populating source directory"
    efreshdir src1 src2
    touch file0 src1/{file1,file2} src2/{file3,file4}

    etestmsg "Creating src.${ftype}"
    archive_create src.${ftype} file0 src1 src2
    assert_archive_contents src.${ftype} file0 src1 src1/{file1,file2} src2 src2/{file3,file4}

    rm src.${ftype}
}

