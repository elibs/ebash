#-----------------------------------------------------------------------------------------------------------------------
#
# dirname tests
#
# These tests verify that our native bash dirname wrapper function behaves identically to /usr/bin/dirname.
#
#-----------------------------------------------------------------------------------------------------------------------

ETEST_dirname_basic()
{
    assert_eq "/usr/bin"  "$(dirname /usr/bin/sort)"
    assert_eq "/usr"      "$(dirname /usr/bin)"
    assert_eq "/"         "$(dirname /usr)"
    assert_eq "."         "$(dirname .)"
    assert_eq "."         "$(dirname ..)"
}

ETEST_dirname_no_slash()
{
    # When there's no slash, dirname should return "."
    assert_eq "." "$(dirname filename)"
    assert_eq "." "$(dirname somefile.txt)"
    assert_eq "." "$(dirname "file with spaces")"
}

ETEST_dirname_trailing_slash()
{
    # Trailing slashes should be handled correctly
    assert_eq "/usr" "$(dirname /usr/bin/)"
    assert_eq "/"    "$(dirname /usr/)"
}

ETEST_dirname_multiple_slashes()
{
    assert_eq "/foo/bar" "$(dirname /foo/bar/baz)"
    assert_eq "/foo"     "$(dirname /foo/bar)"
    assert_eq "foo/bar"  "$(dirname foo/bar/baz)"
    assert_eq "foo"      "$(dirname foo/bar)"
}

ETEST_dirname_relative_paths()
{
    assert_eq "."     "$(dirname ./file)"
    assert_eq ".."    "$(dirname ../file)"
    assert_eq "../.." "$(dirname ../../file)"
}

#-----------------------------------------------------------------------------------------------------------------------
#
# basename tests
#
# These tests verify that our native bash basename wrapper function behaves identically to /usr/bin/basename.
#
#-----------------------------------------------------------------------------------------------------------------------

ETEST_basename_basic()
{
    assert_eq "sort"    "$(basename /usr/bin/sort)"
    assert_eq "bin"     "$(basename /usr/bin)"
    assert_eq "usr"     "$(basename /usr)"
    assert_eq "."       "$(basename .)"
    assert_eq ".."      "$(basename ..)"
}

ETEST_basename_no_slash()
{
    # When there's no slash, basename should return the filename as-is
    assert_eq "filename"     "$(basename filename)"
    assert_eq "somefile.txt" "$(basename somefile.txt)"
}

ETEST_basename_trailing_slash()
{
    # Trailing slashes should be handled correctly
    assert_eq "bin" "$(basename /usr/bin/)"
    assert_eq "usr" "$(basename /usr/)"
}

ETEST_basename_with_suffix()
{
    # Test suffix removal
    assert_eq "file"     "$(basename file.txt .txt)"
    assert_eq "archive"  "$(basename archive.tar.gz .tar.gz)"
    assert_eq "file.txt" "$(basename file.txt .log)"  # suffix doesn't match
    assert_eq ".txt"     "$(basename .txt .txt)"      # entire name is suffix
}

ETEST_basename_relative_paths()
{
    assert_eq "file" "$(basename ./file)"
    assert_eq "file" "$(basename ../file)"
    assert_eq "file" "$(basename ../../file)"
}

ETEST_basename_spaces_in_name()
{
    assert_eq "file with spaces"     "$(basename "/path/to/file with spaces")"
    assert_eq "file with spaces.txt" "$(basename "file with spaces.txt")"
}

#-----------------------------------------------------------------------------------------------------------------------
#
# Verify wrapper functions are being used instead of external binaries
#
# These tests ensure that our native bash implementations are actually being invoked rather than /usr/bin/dirname
# and /usr/bin/basename. This is critical for the performance benefits we're seeking.
#
#-----------------------------------------------------------------------------------------------------------------------

ETEST_dirname_is_function()
{
    # Verify dirname is a shell function, not an external binary
    local type_output
    type_output=$(type -t dirname)
    assert_eq "function" "${type_output}" "dirname should be a function, not external binary"
}

ETEST_basename_is_function()
{
    # Verify basename is a shell function, not an external binary
    local type_output
    type_output=$(type -t basename)
    assert_eq "function" "${type_output}" "basename should be a function, not external binary"
}

#-----------------------------------------------------------------------------------------------------------------------
#
# Flag fallback tests
#
# These tests verify that when flags are passed to basename/dirname, we correctly fall back to the external binary
# which supports those flags.
#
#-----------------------------------------------------------------------------------------------------------------------

ETEST_basename_multiple_flag()
{
    # Create test files
    mkdir -p testdir
    touch testdir/file1.txt testdir/file2.txt testdir/file3.txt

    # Test --multiple flag
    local result
    result=$(basename --multiple testdir/file1.txt testdir/file2.txt testdir/file3.txt)
    assert_eq "file1.txt
file2.txt
file3.txt" "${result}"

    # Test -a flag (short form of --multiple)
    result=$(basename -a testdir/file1.txt testdir/file2.txt)
    assert_eq "file1.txt
file2.txt" "${result}"
}

ETEST_basename_multiple_with_glob()
{
    # This is the actual use case that was failing - using --multiple with glob expansion
    mkdir -p testdir
    touch testdir/mod1.ko testdir/mod2.ko testdir/mod3.ko

    local result
    result=$(basename --multiple testdir/*.ko | sort)
    assert_eq "mod1.ko
mod2.ko
mod3.ko" "${result}"
}

ETEST_basename_suffix_flag()
{
    # Test -s/--suffix flag
    mkdir -p testdir
    touch testdir/file1.txt testdir/file2.txt

    local result
    result=$(basename -s .txt testdir/file1.txt testdir/file2.txt)
    assert_eq "file1
file2" "${result}"

    # Test --suffix= form
    result=$(basename --suffix=.txt testdir/file1.txt testdir/file2.txt)
    assert_eq "file1
file2" "${result}"
}

ETEST_basename_zero_flag()
{
    # Test -z/--zero flag (NUL-terminated output)
    mkdir -p testdir
    touch testdir/file1.txt testdir/file2.txt

    # Count NUL bytes - should have 2 for 2 files
    local nul_count
    nul_count=$(basename -z -a testdir/file1.txt testdir/file2.txt | tr -cd '\0' | wc -c)
    assert_eq 2 "${nul_count}"
}

ETEST_dirname_zero_flag()
{
    # Test -z/--zero flag (NUL-terminated output)
    local nul_count
    nul_count=$(dirname -z /path/to/file | tr -cd '\0' | wc -c)
    assert_eq 1 "${nul_count}"
}

ETEST_basename_help_flag()
{
    # Test --help flag - should produce output containing "Usage"
    local result
    result=$(basename --help 2>&1)
    assert_match "${result}" "Usage"
}

ETEST_dirname_help_flag()
{
    # Test --help flag - should produce output containing "Usage"
    local result
    result=$(dirname --help 2>&1)
    assert_match "${result}" "Usage"
}
